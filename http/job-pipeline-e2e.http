# DELETE {{host}}/api/jobs/{{gradleBuildId}}
# DELETE {{host}}/api/jobs/{{npmBuildId}}
# DELETE {{host}}/api/jobs/{{dockerImageBuildId}}
# DELETE {{host}}/api/jobs/{{k8sDeployDevId}}
