<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 기존 콘솔 출력 유지 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Loki4j Appender — 구조화된 로그를 Loki로 전송 -->
    <springProfile name="!test">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>http://localhost:23100/loki/api/v1/push</url>
            </http>
            <format>
                <label>
                    <pattern>service_name=redpanda-playground,level=%level,logger=%logger{36}</pattern>
                </label>
                <message>
                    <pattern>
                        {"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSS}","level":"%level","logger":"%logger{36}","thread":"%thread","traceId":"%mdc{traceId:-}","spanId":"%mdc{spanId:-}","message":"%message%n%exception"}
                    </pattern>
                </message>
            </format>
        </appender>
    </springProfile>

    <!-- GCP 프로필: 중앙 Loki 서버로 전송 -->
    <springProfile name="gcp">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>http://10.178.0.4:3100/loki/api/v1/push</url>
            </http>
            <format>
                <label>
                    <pattern>service_name=redpanda-playground,level=%level,logger=%logger{36},profile=gcp</pattern>
                </label>
                <message>
                    <pattern>
                        {"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSS}","level":"%level","logger":"%logger{36}","thread":"%thread","traceId":"%mdc{traceId:-}","spanId":"%mdc{spanId:-}","message":"%message%n%exception"}
                    </pattern>
                </message>
            </format>
        </appender>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <springProfile name="!test">
            <appender-ref ref="LOKI"/>
        </springProfile>
    </root>
</configuration>
