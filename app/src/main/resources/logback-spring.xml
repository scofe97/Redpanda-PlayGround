<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 기존 콘솔 출력 유지 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Loki4j Appender — GCP 프로필에서만 활성화 (로컬에서는 Loki 미사용) -->
    <springProfile name="gcp">
        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>http://34.22.78.240:3100/loki/api/v1/push</url>
                <connectionTimeoutMs>5000</connectionTimeoutMs>
                <requestTimeoutMs>5000</requestTimeoutMs>
            </http>
            <format>
                <label>
                    <pattern>service_name=redpanda-playground,level=%level,logger=%logger{36},profile=gcp</pattern>
                </label>
                <message>
                    <pattern>
                        {"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSS}","level":"%level","logger":"%logger{36}","thread":"%thread","traceId":"%mdc{traceId:-}","spanId":"%mdc{spanId:-}","message":"%message%n%exception"}
                    </pattern>
                </message>
            </format>
        </appender>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <springProfile name="gcp">
            <appender-ref ref="LOKI"/>
        </springProfile>
    </root>
</configuration>
