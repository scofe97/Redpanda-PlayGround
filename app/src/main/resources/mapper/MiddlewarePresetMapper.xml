<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.study.playground.preset.mapper.MiddlewarePresetMapper">

    <resultMap id="presetWithEntries" type="com.study.playground.preset.domain.MiddlewarePreset">
        <id property="id" column="p_id"/>
        <result property="name" column="p_name"/>
        <result property="description" column="p_description"/>
        <result property="createdAt" column="p_created_at"/>
        <result property="updatedAt" column="p_updated_at"/>
        <collection property="entries" ofType="com.study.playground.preset.domain.PresetEntry">
            <id property="id" column="e_id"/>
            <result property="presetId" column="e_preset_id"/>
            <result property="category" column="e_category"/>
            <result property="toolId" column="e_tool_id"/>
            <result property="toolName" column="t_name"/>
            <result property="toolUrl" column="t_url"/>
            <result property="toolImplementation" column="t_implementation"/>
        </collection>
    </resultMap>

    <sql id="selectPresetWithEntries">
        SELECT p.id          AS p_id,
               p.name        AS p_name,
               p.description AS p_description,
               p.created_at  AS p_created_at,
               p.updated_at  AS p_updated_at,
               e.id          AS e_id,
               e.preset_id   AS e_preset_id,
               e.category    AS e_category,
               e.tool_id     AS e_tool_id,
               t.name        AS t_name,
               t.url         AS t_url,
               t.implementation AS t_implementation
        FROM middleware_preset p
        LEFT JOIN preset_entry e ON p.id = e.preset_id
        LEFT JOIN support_tool t ON e.tool_id = t.id
    </sql>

    <select id="findAll" resultMap="presetWithEntries">
        <include refid="selectPresetWithEntries"/>
        ORDER BY p.name
    </select>

    <select id="findById" resultMap="presetWithEntries">
        <include refid="selectPresetWithEntries"/>
        WHERE p.id = #{id}
    </select>

    <insert id="insert" parameterType="com.study.playground.preset.domain.MiddlewarePreset"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO middleware_preset (name, description, created_at, updated_at)
        VALUES (#{name}, #{description}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.study.playground.preset.domain.MiddlewarePreset">
        UPDATE middleware_preset
        SET name        = #{name},
            description = #{description},
            updated_at  = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM middleware_preset WHERE id = #{id}
    </delete>

    <select id="countByToolId" resultType="int">
        SELECT COUNT(*) FROM preset_entry WHERE tool_id = #{toolId}
    </select>

</mapper>
