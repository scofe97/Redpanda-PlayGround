{
  "uid": "rp-server",
  "title": "Server Resources",
  "description": "GCP server CPU, memory, disk, network monitoring (node_exporter)",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(node_cpu_seconds_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "CPU Usage",
      "description": "Current CPU utilization percentage",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{server}} ({{instance}})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.7, "color": "yellow" },
              { "value": 0.9, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Memory Usage",
      "description": "Current memory utilization percentage",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})",
          "legendFormat": "{{server}} ({{instance}})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.7, "color": "yellow" },
              { "value": 0.9, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Disk Usage",
      "description": "Root filesystem usage percentage",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\", instance=~\"$instance\"} / node_filesystem_size_bytes{mountpoint=\"/\", instance=~\"$instance\"})",
          "legendFormat": "{{server}} ({{instance}})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.7, "color": "yellow" },
              { "value": 0.9, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU Usage Over Time",
      "description": "CPU utilization trend per server",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{server}} ({{instance}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Usage Over Time",
      "description": "Memory utilization trend per server",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})",
          "legendFormat": "{{server}} ({{instance}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Load Average",
      "description": "System load average (1m, 5m, 15m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_load1{instance=~\"$instance\"}",
          "legendFormat": "{{server}} 1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=~\"$instance\"}",
          "legendFormat": "{{server}} 5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=~\"$instance\"}",
          "legendFormat": "{{server}} 15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Network I/O",
      "description": "Network bytes received and transmitted (eth0)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device=\"ens4\", instance=~\"$instance\"}[5m])",
          "legendFormat": "{{server}} rx",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device=\"ens4\", instance=~\"$instance\"}[5m])",
          "legendFormat": "{{server}} tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Memory Usage Detail",
      "description": "Used / Total memory per server",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemAvailable_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{server}} Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{server}} Available",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5368709120, "color": "yellow" },
              { "value": 7516192768, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Disk Usage Detail",
      "description": "Used / Total disk space per server (root filesystem)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\", instance=~\"$instance\"} - node_filesystem_avail_bytes{mountpoint=\"/\", instance=~\"$instance\"}",
          "legendFormat": "{{server}} Used",
          "refId": "A"
        },
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\", instance=~\"$instance\"}",
          "legendFormat": "{{server}} Available",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 32212254720, "color": "yellow" },
              { "value": 42949672960, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    }
  ]
}
