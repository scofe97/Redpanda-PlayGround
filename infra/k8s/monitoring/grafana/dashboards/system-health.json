{
  "uid": "rp-syshealth",
  "title": "System Health",
  "description": "K8s cluster — service status, pod resources, LGMT stack health",
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Service Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "All Services",
      "description": "UP/DOWN for all scrape targets",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up", "legendFormat": "{{job}} / {{instance}}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }], "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] } } }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Pod Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Pod Memory (rp-oss)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "container_memory_working_set_bytes{namespace=\"rp-oss\", container!=\"\", container!=\"POD\"}", "legendFormat": "{{pod}}/{{container}}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color" },
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 268435456, "color": "yellow" }, { "value": 536870912, "color": "orange" }, { "value": 1073741824, "color": "red" }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Pod Memory (rp-mgm + rp-jenkins)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "container_memory_working_set_bytes{namespace=~\"rp-mgm|rp-jenkins\", container!=\"\", container!=\"POD\"}", "legendFormat": "{{pod}}/{{container}}", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color" },
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 268435456, "color": "yellow" }, { "value": 536870912, "color": "orange" }, { "value": 1073741824, "color": "red" }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pod CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"rp-.*\", container!=\"\", container!=\"POD\"}[5m]))", "legendFormat": "{{pod}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 1, "fillOpacity": 10, "gradientMode": "opacity", "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pod Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"rp-.*\", container!=\"\", container!=\"POD\"})", "legendFormat": "{{pod}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 1, "fillOpacity": 10, "gradientMode": "opacity", "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 102,
      "type": "row",
      "title": "LGMT Stack",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Prometheus TSDB",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "prometheus_tsdb_storage_blocks_bytes", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Prometheus Series",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "prometheus_tsdb_head_series", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Loki Ingestion",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(loki_distributor_bytes_received_total[5m]))", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "fixedColor": "yellow", "mode": "fixed" } } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Tempo Spans",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(tempo_distributor_spans_received_total[5m]))", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Loki Ingestion Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(loki_distributor_bytes_received_total[5m])", "legendFormat": "Loki ingest", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Tempo Traces Received",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(tempo_distributor_spans_received_total[5m])", "legendFormat": "Tempo spans", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Node Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Node Memory Available",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "machine_memory_bytes - sum by (instance) (container_memory_working_set_bytes{id=\"/\"})", "legendFormat": "{{instance}} available", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Node CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (instance) (rate(container_cpu_usage_seconds_total{id=\"/\"}[5m]))", "legendFormat": "{{instance}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
