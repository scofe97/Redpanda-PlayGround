{
  "uid": "rp-overview",
  "title": "Redpanda Overview",
  "description": "Redpanda broker — status, throughput, partitions, consumer lag",
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Broker Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Broker",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=~\".*redpanda.*\"}", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }], "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "vectorized_application_uptime{job=~\".*redpanda.*\"}", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Partitions",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(vectorized_cluster_partition_committed_offset{job=~\".*redpanda.*\"})", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "purple", "mode": "fixed" } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "vectorized_rpc_active_connections{job=~\".*redpanda.*\"}", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Produce Rate",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(vectorized_cluster_partition_bytes_produced_total{job=~\".*redpanda.*\"}[5m]))", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "fixedColor": "green", "mode": "fixed" } } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Fetch Rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(vectorized_cluster_partition_bytes_fetched_total{job=~\".*redpanda.*\"}[5m]))", "legendFormat": "", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Bytes Produced / Fetched",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(vectorized_cluster_partition_bytes_produced_total{job=~\".*redpanda.*\"}[5m]))", "legendFormat": "Produced", "refId": "A" },
        { "expr": "sum(rate(vectorized_cluster_partition_bytes_fetched_total{job=~\".*redpanda.*\"}[5m]))", "legendFormat": "Fetched", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Records Produced / Fetched",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(vectorized_cluster_partition_batches_produced{job=~\".*redpanda.*\"}[5m]))", "legendFormat": "Batches produced", "refId": "A" },
        { "expr": "sum(rate(vectorized_cluster_partition_records_fetched{job=~\".*redpanda.*\"}[5m]))", "legendFormat": "Records fetched", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Consumer Groups",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Consumer Group Lag",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "vectorized_kafka_consumer_group_lag{job=~\".*redpanda.*\"}", "legendFormat": "{{group}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 100, "color": "yellow" }, { "value": 1000, "color": "red" }] } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Partition Offsets (per topic)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "vectorized_cluster_partition_committed_offset{job=~\".*redpanda.*\"}", "legendFormat": "{{redpanda_topic}}/{{redpanda_partition}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 0 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Redpanda Memory",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "container_memory_working_set_bytes{namespace=\"rp-oss\", pod=~\"redpanda.*\", container=\"redpanda\"}", "legendFormat": "{{pod}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Redpanda CPU",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{namespace=\"rp-oss\", pod=~\"redpanda.*\", container=\"redpanda\"}[5m])", "legendFormat": "{{pod}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
